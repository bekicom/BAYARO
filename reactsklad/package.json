{
  "name": "reactsklad",
  "productName": "BAYARO",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "jsbarcode": "^3.12.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.14"
  },
  "build": {
    "appId": "uz.ataway.bayaro",
    "productName": "BAYARO",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BAYARO"
    }
  }
}
